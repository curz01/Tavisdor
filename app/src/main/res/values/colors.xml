<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Solid black behind everything; same edge color the dungeon view paints around the playfield. -->
    <color name="dungeon_bg">#FF000000</color>
    <color name="floor_label_text">#FFB8AE92</color>

    <!-- Title screen text. -->
    <color name="title_text">#FFEFE7D0</color>
    <color name="title_subtitle_text">#FFB8AE92</color>

    <!-- Hero panel slot frames. -->
    <color name="hero_slot_border">#FF8C7A52</color>
    <color name="hero_slot_fill_empty">#FF1E1A12</color>
    <color name="hero_slot_fill_filled">#FF332B1B</color>
    <color name="hero_slot_label">#FFE6D9B6</color>

    <!-- Front/back line row tags above hero panel. -->
    <color name="line_tag_text">#FFB8AE92</color>

    <!-- Hero detail overlay: scrim dims everything behind the panel. -->
    <color name="hero_detail_scrim">#CC000000</color>
    <color name="hero_detail_label_dim">#FFB8AE92</color>
    <color name="hero_detail_value">#FFEFE7D0</color>
    <color name="hero_detail_slot_label">#FFE6D9B6</color>
    <color name="hero_detail_slot_empty">#FF6B6450</color>

    <!-- Skill picker dialog rows. The blink colors themselves live as
         hex constants inside the drawable XMLs so a designer can tweak
         them without editing this palette. -->
    <color name="skill_picker_row_name">#FFEFE7D0</color>
    <color name="skill_picker_row_meta">#FFB8AE92</color>
    <color name="skill_picker_row_desc">#FFC9BC97</color>
    <color name="skill_picker_free_tag">#FFE6C12C</color>
    <color name="skill_picker_passive_tag">#FF8C7A52</color>
    <color name="hero_skill_assign_divider">#FF8C7A52</color>
    <color name="hero_skill_assign_confirm_bg">#FF4A8C55</color>
    <color name="hero_skill_assign_confirm_ripple">#6652B06A</color>

    <!-- Items panel: shares the scrim + parchment palette with the
         hero detail overlay so the two modals read as the same
         family. Gold counter uses a warmer hue to stand out from
         body text. -->
    <color name="items_panel_scrim">#CC000000</color>
    <color name="items_panel_value">#FFEFE7D0</color>
    <color name="items_panel_label_dim">#FFB8AE92</color>
    <color name="items_panel_section_header">#FFE6C12C</color>
    <color name="items_panel_row_empty">#FF6B6450</color>
    <color name="items_panel_gold">#FFE6C12C</color>
    <color name="items_panel_hint">#FFC9BC97</color>
    <color name="items_panel_row_text">#FFEFE7D0</color>
    <color name="items_panel_stack_count">#FFE6C12C</color>

    <!-- Inventory top tabs (Loot green / Equip blue / Mat tan). -->
    <color name="inventory_tab_pickup">#FF3D7345</color>
    <color name="inventory_tab_pickup_selected">#FF4A8C55</color>
    <color name="inventory_tab_pickup_border">#FF1E4F32</color>
    <color name="inventory_tab_equipment">#FF2F4A78</color>
    <color name="inventory_tab_equipment_selected">#FF3B5998</color>
    <color name="inventory_tab_equipment_border">#FF1E3358</color>
    <color name="inventory_tab_ingredients">#FF9E6530</color>
    <color name="inventory_tab_ingredients_selected">#FFD9934D</color>
    <color name="inventory_tab_ingredients_border">#FF6B4210</color>
    <color name="inventory_tab_label">#FF1A1610</color>
    <color name="inventory_tab_body_fill">#FF0F0F0F</color>

    <!-- Slot interiors (accent border comes from the active tab). -->
    <color name="inventory_slot_fill">#FF2D1B14</color>
    <color name="inventory_slot_fill_empty">#FF1A100C</color>
    <!-- Legacy per-tab fills (unused; kept so old drawables still resolve). -->
    <color name="inventory_slot_pickup_fill">@color/inventory_slot_fill</color>
    <color name="inventory_slot_pickup_fill_empty">@color/inventory_slot_fill_empty</color>
    <color name="inventory_slot_equipment_fill">@color/inventory_slot_fill</color>
    <color name="inventory_slot_equipment_fill_empty">@color/inventory_slot_fill_empty</color>
    <color name="inventory_slot_materials_fill">@color/inventory_slot_fill</color>
    <color name="inventory_slot_materials_fill_empty">@color/inventory_slot_fill_empty</color>

    <!-- Combat target-picker overlay (dim out-of-range, tint in-range). -->
    <color name="combat_target_dim">#AA000000</color>
    <color name="combat_target_in_range">#3348B06A</color>
    <color name="combat_target_enemy">#66E6C12C</color>
    <color name="combat_target_splash">#6648A0E8</color>
</resources>
