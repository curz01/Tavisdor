<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Title screen layout. -->
    <dimen name="title_main_text_size">56sp</dimen>
    <dimen name="title_subtitle_text_size">20sp</dimen>
    <dimen name="title_button_min_width">240dp</dimen>
    <dimen name="title_button_vertical_gap">12dp</dimen>

    <!-- Class select screen layout. -->
    <dimen name="class_select_slot_size">120dp</dimen>
    <dimen name="class_select_slot_h_gap">16dp</dimen>
    <dimen name="class_select_slot_v_gap">12dp</dimen>
    <dimen name="class_select_slot_label_text_size">14sp</dimen>

    <!--
      Turn-order strip across the top of the dungeon view during
      COMBAT. Height accommodates a roughly 48dp portrait + a 6dp
      vertical pad on each side (see STRIP_PADDING_VERTICAL_DP in
      TurnOrderBarView).
    -->
    <dimen name="turn_order_bar_height">60dp</dimen>
    <!--
      Top offset that pushes the turn-order strip below the
      system status bar / camera cutout. Activity content is
      drawn edge-to-edge on modern Android, so without this
      gap the portraits can sit underneath the notch. ~32dp
      clears a standard status bar (24dp) plus a small bezel
      buffer.
    -->
    <dimen name="turn_order_bar_top_margin">32dp</dimen>

    <!-- Fixed band for the in-game "Floor N" label (below turn-order strip). -->
    <dimen name="floor_label_band_height">24dp</dimen>
    <dimen name="floor_label_text_size">14sp</dimen>

    <!--
      Width of the up / down scroll buttons that flank the right
      edge of the combat log. Narrow enough not to crowd the text
      column but wide enough to read as an obvious touch target.
    -->
    <dimen name="combat_log_scroll_button_width">36dp</dimen>
    <!-- Collapsed combat log (~4 wrapped lines); expanded is 2× this height. -->
    <dimen name="combat_log_collapsed_height">88dp</dimen>
    <dimen name="combat_log_expanded_height">176dp</dimen>

    <!-- Action bar sits above the hero panel: Menu / Action / Items. -->
    <dimen name="action_bar_height">56dp</dimen>
    <dimen name="action_bar_padding_horizontal">10dp</dimen>
    <dimen name="action_bar_padding_vertical">6dp</dimen>
    <dimen name="action_bar_button_gap">8dp</dimen>

    <!-- Hero panel (persistent bottom 2x2 grid in-game). -->
    <dimen name="hero_panel_height">224dp</dimen>
    <dimen name="hero_panel_slot_size">80dp</dimen>
    <dimen name="hero_panel_slot_h_gap">10dp</dimen>
    <dimen name="hero_panel_slot_v_gap">8dp</dimen>
    <dimen name="hero_panel_padding">12dp</dimen>

    <!-- Hero detail overlay (modal opened by tapping a portrait). -->
    <dimen name="hero_detail_panel_padding">16dp</dimen>
    <dimen name="hero_skill_assign_body_height">600dp</dimen>
    <!-- 75% of assign body — skill book dialog scroll area. -->
    <dimen name="hero_skill_book_scroll_height">405dp</dimen>
    <dimen name="hero_skill_book_title_text">15sp</dimen>
    <dimen name="hero_skill_book_section_text">13sp</dimen>
