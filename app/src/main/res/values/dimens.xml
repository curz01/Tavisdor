    <dimen name="hero_skill_assign_panel_width">368dp</dimen>
    <dimen name="hero_skill_assign_row_gap">10dp</dimen>
    <dimen name="hero_skill_assign_row_pad_h">8dp</dimen>
    <dimen name="hero_skill_assign_row_pad_v">8dp</dimen>
    <dimen name="hero_skill_assign_name_text">16sp</dimen>
    <dimen name="hero_skill_assign_meta_text">13sp</dimen>
    <dimen name="hero_skill_assign_section_text">14sp</dimen>
    <dimen name="hero_skill_assign_header_text">17sp</dimen>
    <dimen name="hero_detail_equip_slot_size">64dp</dimen>
    <dimen name="hero_detail_equip_grid_gap">8dp</dimen>

    <!-- Inventory panel (modal: action-bar Inventory button + post-combat auto-open). -->
    <dimen name="items_panel_width">320dp</dimen>
    <dimen name="items_panel_padding">16dp</dimen>
    <dimen name="items_panel_section_gap">14dp</dimen>
    <!-- Fixed tab body height so the panel footprint stays stable across tabs. -->
    <!-- 3×72dp grid + row gaps + pickup hint and auto-pickup / Pick Up All row. -->
    <dimen name="items_panel_tab_body_height">320dp</dimen>
    <dimen name="inventory_grid_capacity_text">11sp</dimen>
    <!-- Top tab strip on the inventory panel (horizontal, right-aligned, 80% width). -->
    <dimen name="items_panel_top_tab_height">32dp</dimen>
    <dimen name="inventory_tab_height_active">30dp</dimen>
    <dimen name="inventory_tab_height_inactive">28dp</dimen>
    <!-- Inactive tabs sit higher; active tab drops onto the panel frame. -->
    <dimen name="inventory_tab_inactive_lift">1.5dp</dimen>
    <dimen name="inventory_tab_active_overlap">0.5dp</dimen>
    <dimen name="inventory_tab_body_padding">10dp</dimen>
    <!-- Gap between tab strip and tab content (0 = flush with active tab). -->
    <dimen name="items_panel_tab_body_gap">0dp</dimen>
    <dimen name="items_panel_grid_margin_top">6dp</dimen>
    <dimen name="items_panel_summary_gap">8dp</dimen>
