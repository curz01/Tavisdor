<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive launcher icon (API 26+, Android 8.0+). The system composes the
  background and foreground layers and applies its own mask (circle, squircle,
  teardrop, etc.) per OEM. The same XML is reused for round / square / themed
  variants on platforms that support them.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background" />
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
</adaptive-icon>
