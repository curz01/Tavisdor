<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/inventory_tab_equipment_selected" />
            <stroke
                android:width="3dp"
                android:color="@color/inventory_tab_equipment_selected" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/inventory_tab_equipment" />
            <stroke
                android:width="2dp"
                android:color="@color/inventory_tab_equipment_border" />
        </shape>
    </item>
</selector>
